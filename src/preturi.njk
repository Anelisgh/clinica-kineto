---
layout: layouts/base.njk
title: Prețuri
---

<header class="pages-header">
    <div class="container container-900">
        <h1 class="detail-title text-center">Prețuri</h1>
        <div class="services-accent-line mx-auto"></div>
        <p class="pages-subtitle text-center mt-24">
            Toate programele sunt personalizate în funcție de nevoile specifice ale fiecărui copil.
        </p>
    </div>
</header>

<section>
    <div class="container">
        <h2 class="text-center mb-60">Servicii individuale</h2>
        
        <div class="preturi-grid">
            <!-- Evaluare -->
            <div class="pricing-card-individual">
                <h3>Evaluare</h3>
                <div class="pricing-duration">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-icon lucide-clock"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span>40 minute</span>
                </div>
                <div class="pricing-value">200 <span class="pricing-currency">Ron</span></div>
            </div>

            <!-- Kinetoterapie -->
            <div class="pricing-card-individual">
                <h3>Kinetoterapie</h3>
                <div class="pricing-duration">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-icon lucide-clock"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span>50 minute</span>
                </div>
                <div class="pricing-value">180 <span class="pricing-currency">Ron</span></div>
            </div>

            <!-- Terapie manuala -->
            <div class="pricing-card-individual">
                <h3>Terapie manuală</h3>
                <div class="pricing-duration">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-icon lucide-clock"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span>50 minute</span>
                </div>
                <div class="pricing-value">250 <span class="pricing-currency">Ron</span></div>
            </div>
        </div>
    </div>
</section>

<section class="packages-container">
    <div class="container">
        <h2 class="text-center mb-16">Pachete</h2>
        <p class="text-center text-muted mb-60">Economisește alegând un pachet de ședințe adaptat nevoilor copilului tău.</p>
        
        <div class="package-cards-grid">
            <!-- Pachet Kinetoterapie -->
            <div class="package-card">
                <div class="package-card-header">
                    <h3>Kinetoterapie</h3>
                </div>
                <div class="package-list">
                    <div class="package-item">
                        <span class="package-label">4 ședințe kinetoterapie</span>
                        <span class="package-price">680 Ron</span>
                    </div>
                    <div class="package-item">
                        <span class="package-label">8 ședințe kinetoterapie</span>
                        <span class="package-price">1.300 Ron</span>
                    </div>
                    <div class="package-item">
                        <span class="package-label">12 ședințe kinetoterapie</span>
                        <span class="package-price">1.900 Ron</span>
                    </div>
                </div>
            </div>

            <!-- Pachet Terapie Manuala -->
            <div class="package-card">
                <div class="package-card-header">
                    <h3>Terapie manuală</h3>
                </div>
                <div class="package-list">
                    <div class="package-item">
                        <span class="package-label">4 ședințe terapie manuală</span>
                        <span class="package-price">900 Ron</span>
                    </div>
                    <div class="package-item">
                        <span class="package-label">8 ședințe terapie manuală</span>
                        <span class="package-price">1.800 Ron</span>
                    </div>
                    <div class="package-item">
                        <span class="package-label">12 ședințe terapie manuală</span>
                        <span class="package-price">2.600 Ron</span>
                    </div>
                </div>
            </div>

            <!-- Pachet Mixt -->
            <div class="package-card">
                <div class="package-card-header">
                    <h3>Kineto + Terapie manuală</h3>
                </div>
                <div class="package-list">
                    <div class="package-item">
                        <span class="package-label">2 ședințe KT și 2 ședințe TM</span>
                        <span class="package-price">750 Ron</span>
                    </div>
                    <div class="package-item">
                        <span class="package-label">4 ședințe KT și 4 ședințe TM</span>
                        <span class="package-price">1.500 Ron</span>
                    </div>
                    <div class="package-item">
                        <span class="package-label">6 ședințe KT și 6 ședințe TM</span>
                        <span class="package-price">2.200 Ron</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Deplasari Banner -->
        <div class="home-visit-banner">
            <div class="home-visit-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-house-icon lucide-house"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            </div>
            <div class="home-visit-content">
                <h3>Deplasări la domiciliu</h3>
                <p>La cerere se fac deplasări la domiciliu pentru bebelușii până în vârsta de 1 an — <span class="text-accent-bold">300 Ron / ședință</span></p>
            </div>
        </div>

    </div>
</section>

{% include "partials/contact-cta.njk" %}
