<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | PhysioBaby</title>
    <meta name="description" content="{{ description or 'Kinetoterapie pediatrică în București. Ajutăm copiii să crească armonios prin programe personalizate de recuperare.' }}">
    
    {% include "partials/schema.njk" %}
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/assets/img/icon-p.png">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@500;600;700&family=Playfair+Display+SC&display=swap" rel="stylesheet">
    
    <!-- Global CSS -->
    <link rel="stylesheet" href="/assets/css/styles.css">
</head>
<body>

    {% include "partials/navbar.njk" %}

    <main>
        {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}
    {% include "partials/floating-button.njk" %}

    <!-- GDPR WhatsApp Consent Modal -->
    <div id="gdpr-modal" class="gdpr-modal" role="dialog" aria-modal="true" aria-labelledby="gdpr-modal-title" hidden>
        <div class="gdpr-modal-backdrop"></div>
        <div class="gdpr-modal-card">
            <div class="gdpr-modal-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.414 0 0 5.414 0 12.05c0 2.123.552 4.197 1.6 6.037L0 24l6.105-1.602a11.834 11.834 0 005.937 1.598h.005c6.637 0 12.05-5.414 12.05-12.051a11.815 11.815 0 00-3.525-8.497z" fill="white"/>
                </svg>
            </div>
            <h3 id="gdpr-modal-title">Înainte de a continua</h3>
            <p class="gdpr-modal-body">Prin deschiderea WhatsApp, datele tale de contact vor fi prelucrate de PhysioBaby exclusiv în scopul programării.</p>
            <label class="gdpr-checkbox-label">
                <input type="checkbox" id="gdpr-consent-checkbox">
                <span>Sunt de acord cu prelucrarea datelor personale conform <a href="/politica-confidentialitate" target="_blank" rel="noopener noreferrer">Politicii de Confidențialitate</a></span>
            </label>
            <p class="gdpr-warning" id="gdpr-warning" hidden>Te rugăm să bifezi consimțământul pentru a putea continua.</p>
            <div class="gdpr-modal-actions">
                <button id="gdpr-confirm-btn" class="btn btn-accent">Continuă pe WhatsApp</button>
                <button id="gdpr-cancel-btn" class="gdpr-cancel-btn">Anulează</button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="/assets/js/main.js"></script>
</body>
</html>
